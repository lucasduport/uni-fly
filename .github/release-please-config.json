{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "draft": false,
  "prerelease": false,
  "pull-request-header": "⚠️ **Manual step required before merging:** check out this branch, run `uv lock`, and push the updated `uv.lock`. This also triggers CI (workflows do not run on PRs opened by `GITHUB_TOKEN`).",
  "packages": {
    ".": {
      "package-name": "uni-fly",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "packages/worker/pyproject.toml",
        "pyproject.toml"
      ]
    }
  }
}
