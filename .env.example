# Copy to .env and fill in. Do NOT commit .env.

# --- Mistral Workflows runtime ---
# Logical worker grouping; consumed directly by the mistralai-workflows SDK.
# All workers sharing this name form a single deployment and the platform
# distributes tasks across them. Required at startup.
DEPLOYMENT_NAME=unifly-worker

# --- Firefly III ---
FIREFLY_URL=http://localhost:8080
FIREFLY_TOKEN=                # Personal Access Token from Firefly III UI
FIREFLY_APP_KEY=              # Laravel APP_KEY for the Firefly container; format: base64:<openssl rand -base64 32>

# --- Mistral API (used by activities) ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# --- Mistral Workflows payload encryption (AES-256-GCM at the SDK layer) ---
# `partial` mode encrypts only fields typed as EncryptedStrField; everything
# else is plaintext in Studio. Use `full` to encrypt all workflow inputs/outputs.
# Generate a 256-bit key with:
#   uv run python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; print(AESGCM.generate_key(bit_length=256).hex())"
# DO NOT lose this key — encrypted workflows become unreadable without it.
TEMPORAL_PAYLOAD_ENCRYPTION__MODE=partial
TEMPORAL_PAYLOAD_ENCRYPTION__MAIN_KEY=
# Optional: set during key rotation; the SDK tries MAIN_KEY first, falls back to SECONDARY_KEY for decrypt.
# TEMPORAL_PAYLOAD_ENCRYPTION__SECONDARY_KEY=

# --- Companion DB ---
# Only the passwords are required. DATABASE_URL is derived automatically:
#   - in containers: docker-compose.yml builds it from COMPANION_DB_PASSWORD
#   - on the host:   the Makefile builds it from COMPANION_DB_PASSWORD
# Override DATABASE_URL only if you need a different host/port/DB.
COMPANION_DB_PASSWORD=secret           # dev only; override in any non-local deploy
FIREFLY_DB_PASSWORD=secret             # dev only; override in any non-local deploy
# DATABASE_URL=postgresql+asyncpg://companion:<password>@localhost:5432/companion

# --- Observability ---
LOG_LEVEL=INFO
