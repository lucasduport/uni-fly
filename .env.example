# Copy to .env and fill in. Do NOT commit .env.

# --- Mistral Workflows runtime ---
WORKFLOW_TASK_QUEUE=unifly-worker

# --- Firefly III ---
FIREFLY_URL=http://localhost:8080
FIREFLY_TOKEN=                # Personal Access Token from Firefly III UI

# --- Mistral API (used by activities) ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# --- Observability ---
LOG_LEVEL=INFO
